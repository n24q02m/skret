FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/skret ./cmd/skret

FROM alpine:3.20
RUN apk add --no-cache ca-certificates && adduser -D -u 10001 skret
COPY --from=build /out/skret /usr/local/bin/skret
COPY deploy/sync-entrypoint.sh /usr/local/bin/sync-entrypoint.sh
RUN chmod +x /usr/local/bin/sync-entrypoint.sh
USER skret
ENTRYPOINT ["/usr/local/bin/sync-entrypoint.sh"]
